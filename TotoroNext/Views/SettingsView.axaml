<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="using:TotoroNext.ViewModels"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:sty="using:FluentAvalonia.Styling"
             xmlns:fac="using:FluentAvalonia.UI.Controls"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:semi="https://irihi.tech/semi"
             xmlns:mdl="totoro.next/models"
             xmlns:local="using:TotoroNext.Module"
             xmlns:ext="totoro.next/extensions"
             x:DataType="vm:SettingsViewModel"
             Background="{DynamicResource SemiColorBackground0}"
             x:Class="TotoroNext.Views.SettingsView">
    <ContentPage.Styles>
        <sty:FluentAvaloniaTheme />
    </ContentPage.Styles>
    <ScrollViewer>
        <StackPanel Spacing="24" MaxWidth="1000">
            <StackPanel>
                <TextBlock Text="Appearance" FontSize="20" Margin="0 0 0 8" />
                <fac:FASettingsExpander Header="Theme"
                                        IconSource="{ext:PathIconSource Key={x:Static local:CommonIcons.Theme}}">
                    <fac:FASettingsExpander.Footer>
                        <ComboBox ItemsSource="{Binding Themes}"
                                  SelectedItem="{Binding Settings.SelectedTheme, FallbackValue={x:Null}}">
                            <ComboBox.Styles>
                                <semi:SemiTheme Locale="en-US" />
                            </ComboBox.Styles>
                        </ComboBox>
                    </fac:FASettingsExpander.Footer>
                </fac:FASettingsExpander>
                <fac:FASettingsExpander Header="Startup Screen"
                                        IconSource="{ext:PathIconSource Key={x:Static local:CommonIcons.Home}}">
                    <fac:FASettingsExpander.Footer>
                        <ComboBox ItemsSource="{Binding HomeViews}"
                                  SelectedItem="{Binding Settings.HomeView, FallbackValue={x:Null}}">
                            <ComboBox.Styles>
                                <semi:SemiTheme Locale="en-US" />
                            </ComboBox.Styles>
                        </ComboBox>
                    </fac:FASettingsExpander.Footer>
                </fac:FASettingsExpander>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Default Services" FontSize="20" Margin="0 0 0 8" />
                <fac:FASettingsExpander Header="Anime Provider"
                                        Description="Default anime provider"
                                        IconSource="{ext:PathIconSource Key={x:Static local:CommonIcons.VideoLibrary}}">
                    <fac:FASettingsExpander.Footer>
                        <ComboBox ItemsSource="{Binding AnimeProviders}"
                                  SelectedValue="{Binding Settings.SelectedAnimeProvider, FallbackValue={x:Null}}"
                                  SelectedValueBinding="{Binding Id}"
                                  DisplayMemberBinding="{Binding Name}"
                                  Width="300">
                            <ComboBox.Styles>
                                <semi:SemiTheme Locale="en-US" />
                            </ComboBox.Styles>
                        </ComboBox>
                    </fac:FASettingsExpander.Footer>
                </fac:FASettingsExpander>
                <fac:FASettingsExpander Header="Media Player"
                                        Description="Default media player"
                                        IconSource="{ext:PathIconSource Key={x:Static local:CommonIcons.VideoPlayer}}">
                    <fac:FASettingsExpander.Footer>
                        <ComboBox ItemsSource="{Binding MediaEngines}"
                                  SelectedValue="{Binding Settings.SelectedMediaEngine, FallbackValue={x:Null}}"
                                  SelectedValueBinding="{Binding Id}"
                                  DisplayMemberBinding="{Binding Name}"
                                  Width="300">
                            <ComboBox.Styles>
                                <semi:SemiTheme Locale="en-US" />
                            </ComboBox.Styles>
                        </ComboBox>
                    </fac:FASettingsExpander.Footer>
                </fac:FASettingsExpander>
                <fac:FASettingsExpander Header="Tracking"
                                        Description="Default tracking service"
                                        IconSource="{ext:PathIconSource Key={x:Static local:CommonIcons.Tracking}}">
                    <fac:FASettingsExpander.Footer>
                        <ComboBox ItemsSource="{Binding TrackingServices}"
                                  SelectedValue="{Binding Settings.SelectedTrackingService, FallbackValue={x:Null}}"
                                  SelectedValueBinding="{Binding Id}"
                                  DisplayMemberBinding="{Binding Name}"
                                  Width="300">
                            <ComboBox.Styles>
                                <semi:SemiTheme Locale="en-US" />
                            </ComboBox.Styles>
                        </ComboBox>
                    </fac:FASettingsExpander.Footer>
                    <fac:FASettingsExpanderItem>
                        <fac:FASettingsExpanderItem.Footer>
                            <Button Content="Sync"
                                    Command="{Binding SyncListCommand}">
                                <Button.Styles>
                                    <semi:SemiTheme Locale="en-US" />
                                </Button.Styles>
                            </Button>
                        </fac:FASettingsExpanderItem.Footer>
                    </fac:FASettingsExpanderItem>
                </fac:FASettingsExpander>
                <fac:FASettingsExpander Header="Media Segments"
                                        Description="Default media segments provider"
                                        IconSource="{ext:PathIconSource Key={x:Static local:CommonIcons.SkipSegments}}">
                    <fac:FASettingsExpander.Footer>
                        <ComboBox ItemsSource="{Binding SegmentProviders}"
                                  SelectedValue="{Binding Settings.SelectedSegmentsProvider, FallbackValue={x:Null}}"
                                  SelectedValueBinding="{Binding Id}"
                                  DisplayMemberBinding="{Binding Name}"
                                  Width="300">
                            <ComboBox.Styles>
                                <semi:SemiTheme Locale="en-US" />
                            </ComboBox.Styles>
                        </ComboBox>
                    </fac:FASettingsExpander.Footer>
                </fac:FASettingsExpander>
                <fac:FASettingsExpander Header="Torrent Stream"
                                        Description="Default torrent stream service"
                                        IconSource="{ext:PathIconSource Key={x:Static local:CommonIcons.Torrent}}">
                    <fac:FASettingsExpander.Footer>
                        <ComboBox ItemsSource="{Binding TorrentStreamServices}"
                                  SelectedValue="{Binding Settings.SelectedTorrentService, FallbackValue={x:Null}}"
                                  SelectedValueBinding="{Binding Id}"
                                  DisplayMemberBinding="{Binding Name}"
                                  Width="300">
                            <ComboBox.Styles>
                                <semi:SemiTheme Locale="en-US" />
                            </ComboBox.Styles>
                        </ComboBox>
                    </fac:FASettingsExpander.Footer>
                </fac:FASettingsExpander>
                <fac:FASettingsExpander Header="Torrent Client"
                                        Description="Default client to download torrents"
                                        IconSource="{ext:PathIconSource Key={x:Static local:CommonIcons.TorrentClient}}">
                    <fac:FASettingsExpander.Footer>
                        <ComboBox ItemsSource="{Binding TorrentClients}"
                                  SelectedValue="{Binding Settings.SelectedTorrentClient, FallbackValue={x:Null}}"
                                  SelectedValueBinding="{Binding Id}"
                                  DisplayMemberBinding="{Binding Name}"
                                  Width="300">
                            <ComboBox.Styles>
                                <semi:SemiTheme Locale="en-US" />
                            </ComboBox.Styles>
                        </ComboBox>
                    </fac:FASettingsExpander.Footer>
                </fac:FASettingsExpander>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Auto Skip Settings" FontSize="20" Margin="0 0 0 8" />
                <fac:FASettingsExpander Header="Openings"
                                        Description="How to handle openings"
                                        IconSource="{ext:PathIconSource Key={x:Static local:CommonIcons.Opening}}">
                    <fac:FASettingsExpander.Footer>
                        <u:EnumSelector EnumType="mdl:SkipMethod"
                                        Value="{Binding Settings.OpeningSkipMethod, FallbackValue={x:Null}}"
                                        Width="300">
                            <u:EnumSelector.Styles>
                                <semi:SemiTheme Locale="en-US" />
                            </u:EnumSelector.Styles>
                        </u:EnumSelector>
                    </fac:FASettingsExpander.Footer>
                </fac:FASettingsExpander>
                <fac:FASettingsExpander Header="Endings"
                                        Description="How to handle endings"
                                        IconSource="{ext:PathIconSource Key={x:Static local:CommonIcons.Ending}}">
                    <fac:FASettingsExpander.Footer>
                        <u:EnumSelector EnumType="mdl:SkipMethod"
                                        Value="{Binding Settings.EndingSkipMethod, FallbackValue={x:Null}}"
                                        Width="300">
                            <u:EnumSelector.Styles>
                                <semi:SemiTheme Locale="en-US" />
                            </u:EnumSelector.Styles>
                        </u:EnumSelector>
                    </fac:FASettingsExpander.Footer>
                </fac:FASettingsExpander>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Updates" FontSize="20" Margin="0 0 0 8" />
                <fac:FASettingsExpander Header="Check of updates"
                                        Description="{Binding CurrentVersion}"
                                        IconSource="{ext:PathIconSource Key={x:Static local:CommonIcons.Update}}">
                    <fac:FASettingsExpander.Footer>
                        <Button Content="Check" Command="{Binding CheckForUpdatesCommand}">
                            <Button.Styles>
                                <semi:SemiTheme Locale="en-US" />
                            </Button.Styles>
                        </Button>
                    </fac:FASettingsExpander.Footer>
                </fac:FASettingsExpander>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</ContentPage>