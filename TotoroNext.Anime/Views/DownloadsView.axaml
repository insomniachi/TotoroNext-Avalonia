<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:TotoroNext.Anime.ViewModels"
             xmlns:c="clr-namespace:TotoroNext.Module.Converters;assembly=TotoroNext.Module"
             xmlns:ac="clr-namespace:TotoroNext.Anime.Abstractions;assembly=TotoroNext.Anime.Abstractions"
             xmlns:ail="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="viewModels:DownloadsViewModel"
             x:Class="TotoroNext.Anime.Views.DownloadsView">
    <ContentPage.Styles>
        <Style Selector="Button.downloading">
            <Setter Property="Content" Value="Pause" />
        </Style>
        <Style Selector="Button.paused">
            <Setter Property="Content" Value="Resume" />
        </Style>
        <Style Selector="TextBlock.cancelled">
            <Setter Property="TextDecorations" Value="Strikethrough" />
        </Style>
    </ContentPage.Styles>
    <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Downloads}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="16" Background="{DynamicResource SemiColorTertiaryLightActive}" CornerRadius="8">
                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="16">
                            <Image
                                Height="100"
                                Stretch="Uniform"
                                ail:ImageLoader.Source="{Binding Anime.Image}" />

                            <StackPanel Spacing="8" Grid.Column="1">
                                <TextBlock Text="{Binding Anime.Title}" FontWeight="Bold" FontSize="15"
                                           Classes.cancelled="{Binding IsCancelled}" />
                                <TextBlock FontSize="12"
                                           Classes.cancelled="{Binding IsCancelled}">
                                    <Run Text="Episode -" />
                                    <Run Text="{Binding Episode.Number}" />
                                </TextBlock>
                                <ProgressBar Value="{Binding Progress}"
                                             IsIndeterminate="{Binding !DownloadStarted}"
                                             ShowProgressText="True"
                                             IsVisible="{Binding !IsCompleted}">
                                    <ProgressBar.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="Value" Duration="0:0:0.3" />
                                        </Transitions>
                                    </ProgressBar.Transitions>
                                </ProgressBar>
                                <Grid ColumnDefinitions="*, Auto" Margin="0 8 0 0" IsVisible="{Binding !IsCompleted}">
                                    <TextBlock
                                        IsVisible="{Binding Path=., Converter={x:Static ac:Converters.IsNotYtdlpDownloadOperationConverter}}">
                                        <Run
                                            Text="{Binding Speed, Converter={x:Static c:Converters.DownloadSpeedConverter}}" />
                                        <Run Text="-" />
                                        <Run
                                            Text="{Binding DownloadedBytes, Converter={x:Static c:Converters.ByteToStringConverter}}" />
                                        <Run Text="of" />
                                        <Run
                                            Text="{Binding TotalBytes, Converter={x:Static c:Converters.ByteToStringConverter}}" />
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Spacing="4" Grid.Column="1"
                                                IsVisible="{Binding Path=., Converter={x:Static ac:Converters.IsNotYtdlpDownloadOperationConverter}}">
                                        <Button Command="{Binding TogglePauseResumeCommand}"
                                                Classes.paused="{Binding IsPaused}"
                                                Classes.downloading="{Binding !IsPaused}" />
                                        <Button Content="Cancel" Command="{Binding CancelCommand}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="4" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </ScrollViewer>
</ContentPage>