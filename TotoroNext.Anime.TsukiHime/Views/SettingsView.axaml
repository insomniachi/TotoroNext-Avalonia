<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:controls="totoro.next/controls"
             xmlns:local="clr-namespace:TotoroNext.Anime.TsukiHime"
             xmlns:viewModels="clr-namespace:TotoroNext.Anime.TsukiHime.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="viewModels:SettingsViewModel"
             x:Class="TotoroNext.Anime.TsukiHime.Views.SettingsView">
    <Grid RowDefinitions="Auto,*" RowSpacing="16">
        <Image Grid.Row="0"
               Stretch="UniformToFill"
               Width="600" />
        <u:Form Grid.Row="1" HorizontalAlignment="Stretch">

            <controls:SettingsExpander Header="Group"
                                       Description="Select the group to display">
                <controls:SettingsExpander.Editor>
                    <AutoCompleteBox ItemsSource="{x:Static local:TsukiHimeGroups.Groups}"
                                     SelectedItem="{Binding SelectedGroup}"
                                     ValueMemberBinding="{ReflectionBinding Name}"
                                     Width="300">
                        <AutoCompleteBox.ItemTemplate>
                            <DataTemplate DataType="local:GroupDescriptor">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </AutoCompleteBox.ItemTemplate>
                    </AutoCompleteBox>
                </controls:SettingsExpander.Editor>
            </controls:SettingsExpander>

            <controls:ModuleOptionsEditor Options="{Binding EditableSettings}"
                                          IsVisible="{Binding EditableSettings, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <Button Content="Fetch Groups"
                    u:FormItem.NoLabel="True"
                    Theme="{DynamicResource SolidButton}"
                    HorizontalAlignment="Stretch"
                    Command="{Binding FetchGroupsCommand}" />
        </u:Form>
    </Grid>
</ContentPage>